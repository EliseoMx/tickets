CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_BCC_CIERRE=
SITE_URL=http://127.0.0.1:8000

# Puerto donde corre `python manage.py runserver` (si no se pasa uno explícito
# como argumento, ej. `runserver 0.0.0.0:9000`)
PORT=8000

# Clave secreta de Django. En producción, genera una propia y única
# (ej. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
# y NUNCA la compartas ni la subas a git.
SECRET_KEY=

# En desarrollo local puede quedar en True. En producción SIEMPRE debe ser False.
DEBUG=True

# Dominios/IPs desde los que se puede servir el sistema, separados por coma
# (ej. midominio.com,www.midominio.com). En desarrollo local basta con lo de abajo.
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de datos. Si se deja vacío (o distinto de "postgresql"/"mssql"), el sistema
# usa SQLite (db.sqlite3) automáticamente. Para PostgreSQL, pon DB_ENGINE=postgresql.
# Para SQL Server (Express u otra edición), pon DB_ENGINE=mssql.
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Solo si DB_ENGINE=mssql: para instancia nombrada (ej. SQL Server Express) usa
# DB_HOST=localhost\NOMBRE_INSTANCIA y deja DB_PORT vacío (se resuelve solo vía
# SQL Server Browser). DB_ODBC_DRIVER debe coincidir con el driver ODBC instalado
# en Windows (revisa con: Get-OdbcDriver en PowerShell).
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Cuenta de administrador protegida (se crea sola tras cada `migrate` si no existe).
# No se puede editar, desactivar ni eliminar desde la interfaz. Llena esto solo en tu
# .env local — nunca lo subas a git ni se lo compartas a nadie más que el desarrollador.
ADMIN_PROTEGIDO_USERNAME=
ADMIN_PROTEGIDO_EMAIL=
ADMIN_PROTEGIDO_TELEFONO=
ADMIN_PROTEGIDO_PASSWORD=

# Textos personalizables (opcional; si se dejan vacíos, se usan estos valores por defecto)
NOMBRE_SISTEMA=Atención al Cliente
TEXTO_SELECCION_EMPRESA=Selecciona una empresa

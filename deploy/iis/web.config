<?xml version="1.0" encoding="UTF-8"?>
<!--
  Ejemplo de configuración de IIS para usarlo como proxy inverso hacia Waitress.
  Copia este archivo a la carpeta física del sitio en IIS (la que configures en
  "Agregar sitio web"). Requiere tener instalados los módulos gratuitos de
  Microsoft "Application Request Routing" (ARR) y "URL Rewrite".

  Ajusta el puerto (8000) si corriste waitress-serve con otro distinto.
  Ver instrucciones completas en el README, sección "Despliegue en Windows con IIS".
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToWaitress" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
